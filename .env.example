# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE=your-service-role-key

# ─── Kairos AI — Provedores (configure ao menos 1) ──────────────────────────

# Google Gemini 1.5 Flash (gratuito) — pegar em: aistudio.google.com
GOOGLE_AI_API_KEY=

# DeepSeek (barato, ótimo para sermões/documentos) — pegar em: platform.deepseek.com
DEEPSEEK_API_KEY=

# Alternativa: OpenRouter (acesso a múltiplos modelos)
OPENROUTER_API_KEY=

# ─── Configuração da IA ──────────────────────────────────────────────────────
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Kairos

# ─── Pagamentos (Stripe) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
